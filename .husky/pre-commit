#!/usr/bin/env bash

# PATH 설정 (IDE에서 커밋 시 node/pnpm을 찾을 수 있도록)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
export PATH="$HOME/Library/pnpm:$PATH"

# 🔒 보안 취약점 스캔
bash scripts/security-scan.sh

# TypeScript 타입 체크
echo ""
echo "Running TypeScript type check..."
pnpm tsc --noEmit

# 스테이징 파일 검사 (format, lint)
echo "Running lint-staged..."
pnpm exec lint-staged

# 유닛 테스트 / 기능 테스트
echo "Running unit test / function test..."
pnpm test run

# audit fix — 프로덕션 의존성의 critical 취약점만 커밋 차단
# moderate/high는 mermaid>lodash-es 등 unfixable transitive dep 존재로 허용
echo "Running pnpm audit fix..."
pnpm audit fix --prod --audit-level=critical