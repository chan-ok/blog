# 기본: 텍스트 파일은 자동 감지 후 LF로 정규화
* text=auto eol=lf

# 명시적 텍스트 파일 (LF 강제)
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mts       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.sh        text eol=lf
*.env*      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# 바이너리 파일 (변환 금지)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.avif      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
