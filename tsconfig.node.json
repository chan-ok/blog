{
  "include": ["vite.config.ts"],
  "exclude": ["node_modules", ".husky", ".netlify", ".storybook", "dist"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    },

    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["esnext"],

    "noEmit": true,
    "skipLibCheck": true,
    "composite": true,
    "incremental": true,
    "isolatedModules": true,
    "resolveJsonModule": true,

    "strict": true,
    "esModuleInterop": true
  }
}
